                    <img src="../images/<%= hoteles.img %>" alt="Hotel">
                    <div class="destino">
                        <i class=" icono fas fa-globe-americas"></i>
                        <h2 class="tCard"><%= hoteles.titulo %></h2>
                        <div class="description">
                            <p class="subTcard"><%= hoteles.descripcion %></p>
                    </div>
                </article>
                <% }) %>

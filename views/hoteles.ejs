    <main>
        <section class="containerFormHoteles">
            <form class="formHoteles" action="#" autocomplete="off">
                <div class="mainForm">
                    <div class="select2">
                        <label for="destino">Voy a hospedarme en</label>
                        <select name="provincia" id="provincia">
                            <option value="">- Selecciona -</option>
                            <option value="">Buenos Aires</option>
                            <option value="">Mendoza</option>
                            <option value="">Misiones</option>
                            <option value="">Bariloche</option>
                            <option value="">Salta</option>
                            <option value="">Neuquen</option>
                        </select>
                    </div>
                    <div class="select3">
                        <label for="salida">Entrada</label>
                        <input type="date" name="salida" id="salida" placeholder="Ingrese fecha de salida" />
                    </div>
                    <div class="select4">
                        <label for="salida">Salida</label>
                        <input type="date" name="salida" id="salida" placeholder="Ingrese fecha de regreso" />
                    </div>
                    <div class="select3">
                        <input type="text" name="personas" id="personas"
                            placeholder="Pesrsonas" />
                    </div>
                    <div class="submit-button">
                        <input type="submit" value="Buscar">
                    </div>
                </div>
            </form>
        </section>
        <section class="destinos">
            <span>Dulces sueños</span>
            <h2>Hoteles</h2>

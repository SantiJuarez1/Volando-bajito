<%-include('partials/head') %>
<body>
    <header>
        <%-include('partials/nav') %>
    </header>
<main>
    <div class="container-login">
        <h1 class="title">Ingresa a tu cuenta</h1>
        <div class="form-checkbox">¿No estas registrado? <a href="/register">Crea tu cuenta Aqui</a>
            </div>
        <form action="#" autocomplete="off">
            <div class="main-user-information">
                <div class="user-input-box">
                    <label for="username">Usuario</label>
                    <input type="text" name="username" id="username" placeholder="Ingresa tu usuario"/>
                </div>
                <div class="user-input-box user-input-password">
                    <label for="password">Contraseña</label>
                    <input type="password" name="password" id="password" placeholder="Ingrese su contraseña"/>
                </div>
                <div class="form-checkbox">
                    <input type="checkbox" name="remember-me" id="remember-me">
                    <label for="remember-me">Recordar mi contraseña</label>
                </div>
                <div class="form-submit-button">
                    <input type="submit" value="Ingresar">
                </div>
            </div>
        </form>
    </div>
    </main>
</body>  
<%- include('partials/footer') %>
</html>